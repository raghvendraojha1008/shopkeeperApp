        android:name="com.shopkeeper.ledger.ui.reports.ReportsFragment"
        android:label="ReportsFragment" />

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.shopkeeper.ledger.ui.analytics.AnalyticsFragment"
        android:label="AnalyticsFragment" />

    <fragment
