    <fragment
        android:id="@+id/expensesFragment"
        android:name="com.shopkeeper.ledger.ui.expenses.ExpensesFragment"
        android:label="ExpensesFragment" />

    <fragment
        android:id="@+id/vehiclesFragment"
        android:name="com.shopkeeper.ledger.ui.vehicles.VehiclesFragment"
        android:label="VehiclesFragment" />

    <fragment
