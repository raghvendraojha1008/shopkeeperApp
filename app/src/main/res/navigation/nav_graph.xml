<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.shopkeeper.ledger.ui.SplashFragment"
        android:label="SplashFragment">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboardingFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.shopkeeper.ledger.ui.auth.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_login_to_forgotPassword"
            app:destination="@id/forgotPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.shopkeeper.ledger.ui.auth.ForgotPasswordFragment"
        android:label="ForgotPasswordFragment" />

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.shopkeeper.ledger.ui.auth.OnboardingFragment"
        android:label="OnboardingFragment">
        <action
            android:id="@+id/action_onboarding_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.shopkeeper.ledger.ui.dashboard.DashboardFragment"
        android:label="DashboardFragment">
        <action
            android:id="@+id/action_dashboard_to_ledger"
            app:destination="@id/ledgerFragment" />
        <action
            android:id="@+id/action_dashboard_to_bulkImport"
            app:destination="@id/bulkImportFragment" />
        <action
            android:id="@+id/action_dashboard_to_stockValuation"
            app:destination="@id/stockValuationFragment" />
        <action
            android:id="@+id/action_dashboard_to_salesDashboard"
            app:destination="@id/salesDashboardFragment" />
        <action
            android:id="@+id/action_dashboard_to_purchaseDashboard"
            app:destination="@id/purchaseDashboardFragment" />
        <action
            android:id="@+id/action_dashboard_to_analytics"
            app:destination="@id/analyticsFragment" />
        <action
            android:id="@+id/action_dashboard_to_pending"
            app:destination="@id/pendingFragment" />
        <action
            android:id="@+id/action_dashboard_to_reports"
            app:destination="@id/reportsFragment" />
        <action
            android:id="@+id/action_dashboard_to_vehicles"
            app:destination="@id/vehiclesFragment" />
        <action
            android:id="@+id/action_dashboard_to_gameTimeline"
            app:destination="@id/gameTimelineFragment" />
        <action
            android:id="@+id/action_dashboard_to_expenses"
            app:destination="@id/expensesFragment" />
        <action
            android:id="@+id/action_dashboard_to_transactions"
            app:destination="@id/transactionsFragment" />
    </fragment>

    <fragment
        android:id="@+id/inventoryFragment"
        android:name="com.shopkeeper.ledger.ui.inventory.InventoryFragment"
        android:label="InventoryFragment">
        <action
            android:id="@+id/action_inventory_to_itemDetail"
            app:destination="@id/itemDetailFragment" />
        <action
            android:id="@+id/action_inventory_to_waste"
            app:destination="@id/wasteFragment" />
        <action
            android:id="@+id/action_inventory_to_barcode"
            app:destination="@id/barcodeFragment" />
    </fragment>

    <fragment
        android:id="@+id/itemDetailFragment"
        android:name="com.shopkeeper.ledger.ui.inventory.ItemDetailFragment"
        android:label="ItemDetailFragment">
        <action
            android:id="@+id/action_itemDetail_to_waste"
            app:destination="@id/wasteFragment" />
