        android:name="com.shopkeeper.ledger.ui.parties.PartiesFragment"
        android:label="PartiesFragment">
        <action
            android:id="@+id/action_parties_to_partyDetail"
            app:destination="@id/partyDetailFragment" />
        <action
            android:id="@+id/action_parties_to_partyStatement"
            app:destination="@id/partyStatementFragment" />
    </fragment>

    <fragment
        android:id="@+id/partyDetailFragment"
        android:name="com.shopkeeper.ledger.ui.parties.PartyDetailFragment"
        android:label="PartyDetailFragment" />

    <fragment
        android:id="@+id/partyStatementFragment"
        android:name="com.shopkeeper.ledger.ui.parties.PartyStatementFragment"
        android:label="PartyStatementFragment" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.shopkeeper.ledger.ui.settings.SettingsFragment"
        android:label="SettingsFragment">
        <action
            android:id="@+id/action_settings_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_settings_to_automation"
            app:destination="@id/automationFragment" />
        <action
            android:id="@+id/action_settings_to_security"
            app:destination="@id/securityFragment" />
        <action
            android:id="@+id/action_settings_to_aiSettings"
            app:destination="@id/aiSettingsFragment" />
        <action
            android:id="@+id/action_settings_to_fieldVisibility"
            app:destination="@id/fieldVisibilityFragment" />
        <action
            android:id="@+id/action_settings_to_userManagement"
            app:destination="@id/userManagementFragment" />
        <action
            android:id="@+id/action_settings_to_themePicker"
            app:destination="@id/themePickerFragment" />
        <action
            android:id="@+id/action_settings_to_invoiceTemplate"
            app:destination="@id/invoiceTemplateFragment" />
        <action
            android:id="@+id/action_settings_to_dataZone"
            app:destination="@id/dataZoneFragment" />
        <action
            android:id="@+id/action_settings_to_customLists"
            app:destination="@id/customListsFragment" />
    </fragment>

