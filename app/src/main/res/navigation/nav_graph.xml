        android:label="LedgerFragment">
        <action
            android:id="@+id/action_ledger_to_entryDetail"
            app:destination="@id/entryDetailFragment" />
        <action
            android:id="@+id/action_ledger_to_invoicePreview"
            app:destination="@id/invoicePreviewFragment" />
        <action
            android:id="@+id/action_ledger_to_receiptPreview"
            app:destination="@id/receiptPreviewFragment" />
    </fragment>

